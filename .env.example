# =============================================================================
# BlogChoT - Environment Variables
# =============================================================================
#
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# All others are server-only (API routes, server components).
#
# On Vercel: set in Project Settings > Environment Variables.
# =============================================================================


# --- Site URL -----------------------------------------------------------------
# Used for canonical URLs, OG images, sitemap, and feed links.
# Dev: http://localhost:3000 | Prod: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000


# --- Auth (NextAuth.js v5) ---------------------------------------------------
# Generate secret: npx auth secret
# GitHub OAuth App: https://github.com/settings/developers
# ADMIN_EMAILS: comma-separated emails allowed to access /admin
# WARNING: SENSITIVE - never commit real values. Set only in Vercel env.
AUTH_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
ADMIN_EMAILS=you@example.com


# --- Umami Analytics ---------------------------------------------------------
# Sign up at https://umami.is or self-host.
# Leave blank to disable.
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_URL=https://analytics.umami.is/script.js


# --- Resend (Newsletter) ------------------------------------------------------
# Get API key: https://resend.com/api-keys
# WARNING: SENSITIVE - never commit real values.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_AUDIENCE_ID=


# --- Upstash Redis (View Counter + Rate Limiting) ----------------------------
# Create free database: https://console.upstash.com
# WARNING: SENSITIVE - never commit real values.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=


# --- Vercel Blob (Image Uploads in Admin) -----------------------------------
# Auto-provided on Vercel when you add Blob storage to your project.
# For local dev: vercel env pull
# WARNING: SENSITIVE - never commit real values.
BLOB_READ_WRITE_TOKEN=


# --- Bundle Analyzer (dev only) ---------------------------------------------
# Set to "true" to generate bundle report: ANALYZE=true npm run build
# ANALYZE=false
